# Dockerfile used by GoReleaser for multi-arch builds
FROM scratch

ARG TARGETPLATFORM

WORKDIR /root/

# Copy the binary from GoReleaser context
COPY $TARGETPLATFORM/gopherstack .

# Expose port 8000
EXPOSE 8000

# OCI label pointing to the source repository
LABEL org.opencontainers.image.source="https://github.com/blackbirdworks/gopherstack"

# Command to run the executable
CMD ["./gopherstack"]
